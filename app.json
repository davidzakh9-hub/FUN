{
  "expo": {
    "name": "NFC Pay",
    "slug": "nfc-pay-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nfcpay",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nfcpay.wallet",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes to receive payments.",
        "NFCReaderUsageDescription": "Tap NFC tags to send or receive payments instantly.",
        "NSFaceIDUsageDescription": "Authenticate payments with Face ID.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nfcpay.wallet",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "NFC",
        "CAMERA",
        "VIBRATE",
        "android.permission.NFC"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Tap NFC devices to send or receive payments.",
          "selectIdentifiers": [
            "A0000002471001"
          ],
          "systemCodes": [
            "FE00"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "6404118a-b5a9-4631-bfd1-dca58ceddc04"
      },
      "router": {}
    },
    "owner": "dwf"
  }
}
